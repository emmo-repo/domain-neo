@prefix : <https://w3id.org/emmo/domain/decommissioning#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix elite: <https://w3id.org/emmo/emmo-lite#> .
@base <https://w3id.org/emmo/domain/decommissioning#> .

<https://w3id.org/emmo/domain/decommissioning> rdf:type owl:Ontology ;
                                                owl:imports <https://w3id.org/emmo/domain/neo/neo> ;
                                                rdfs:comment "Ontologia di decommissioning che estende NEO"@it ,
                                                             "Manca inserire le relazioni e le referenze per ogni classe" ;
                                                rdfs:isDefinedBy "https://www.iaea.org/publications/15456/a-taxonomy-for-the-decommissioning-of-nuclear-facilities" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/contributor
<http://purl.org/dc/terms/contributor> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:AnnotationProperty .


#################################################################
#    Classes
#################################################################

###  https://w3id.org/emmo/domain/decommissioning#Characterization
:Characterization rdf:type owl:Class ;
                  rdfs:subClassOf elite:Characterisation ;
                  <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> """the determination of the physical, chemical and radiological nature of
something for the purpose of informing activities and decisions.""" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :Characterization ;
   owl:annotatedProperty <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> ;
   owl:annotatedTarget """the determination of the physical, chemical and radiological nature of
something for the purpose of informing activities and decisions.""" ;
   rdfs:isDefinedBy "https://www.iaea.org/publications/15456/a-taxonomy-for-the-decommissioning-of-nuclear-facilities 2.2.9."
 ] .


###  https://w3id.org/emmo/domain/decommissioning#CleanUp
:CleanUp rdf:type owl:Class ;
         rdfs:subClassOf elite:Process ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty elite:isSubProcessOf ;
                           owl:someValuesFrom :Decommissioning
                         ] ;
         <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> """the removal of contaminated soil and other materials from an area within the
authorized boundary of a facility, typically performed under the authorization for
decommissioning for the purpose of reaching the defined end state.""" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :CleanUp ;
   owl:annotatedProperty <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> ;
   owl:annotatedTarget """the removal of contaminated soil and other materials from an area within the
authorized boundary of a facility, typically performed under the authorization for
decommissioning for the purpose of reaching the defined end state.""" ;
   rdfs:isDefinedBy "IAEA-TECDOC-2029,Taxonomyfordecommissiong 2.2.6."
 ] .


###  https://w3id.org/emmo/domain/decommissioning#ClearanceVerification
:ClearanceVerification rdf:type owl:Class ;
                       rdfs:subClassOf elite:Process .


###  https://w3id.org/emmo/domain/decommissioning#ContainerForTransportation
:ContainerForTransportation rdf:type owl:Class ;
                            rdfs:subClassOf elite:Process ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty elite:isSubProcessOf ;
                                              owl:someValuesFrom :Dismantling
                                            ] ;
                            <http://www.w3.org/2004/02/skos/core#altLabel> "Containment" ;
                            <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> """methods or physical structures designed to prevent or control the release
and the dispersion of radioactive substances.""" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :ContainerForTransportation ;
   owl:annotatedProperty <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> ;
   owl:annotatedTarget """methods or physical structures designed to prevent or control the release
and the dispersion of radioactive substances.""" ;
   rdfs:isDefinedBy "https://www.iaea.org/publications/15456/a-taxonomy-for-the-decommissioning-of-nuclear-facilities"
 ] .


###  https://w3id.org/emmo/domain/decommissioning#ControlledArea
:ControlledArea rdf:type owl:Class ;
                rdfs:subClassOf elite:Object ;
                <http://www.w3.org/2004/02/skos/core#definition> """area in which specific protection measures and safety provisions are or could be required for:
a) controlling normal exposures or preventing the spread of contamination during normal working conditions;
b) preventing or limiting the extent of potential exposures.""" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :ControlledArea ;
   owl:annotatedProperty <http://www.w3.org/2004/02/skos/core#definition> ;
   owl:annotatedTarget """area in which specific protection measures and safety provisions are or could be required for:
a) controlling normal exposures or preventing the spread of contamination during normal working conditions;
b) preventing or limiting the extent of potential exposures.""" ;
   rdfs:isDefinedBy "[SOURCE:IAEA Safety Series No.115:1996]"
 ] .


###  https://w3id.org/emmo/domain/decommissioning#Cutting
:Cutting rdf:type owl:Class ;
         rdfs:subClassOf elite:Process ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty elite:isBefore ;
                           owl:someValuesFrom :ContainerForTransportation
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty elite:isSubProcessOf ;
                           owl:someValuesFrom :Dismantling
                         ] ;
         <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> """the act of separating or dividing structures, systems, components or waste using
force or energy to divide the material.""" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :Cutting ;
   owl:annotatedProperty <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> ;
   owl:annotatedTarget """the act of separating or dividing structures, systems, components or waste using
force or energy to divide the material.""" ;
   rdfs:isDefinedBy "https://www.iaea.org/publications/15456/a-taxonomy-for-the-decommissioning-of-nuclear-facilities"
 ] .


###  https://w3id.org/emmo/domain/decommissioning#Decommissioning
:Decommissioning rdf:type owl:Class ;
                 rdfs:subClassOf elite:Process ;
                 rdfs:comment """The use of the term decommissioning implies that no further use of the facility (or
part thereof) for its existing purpose is foreseen""" ;
                 <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> """the set of administrative and technical actions taken to allow the
removal of some or all of the regulatory controls from a facility. This does not apply for that part of a disposal facility in which radioactive waste is emplaced.""" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :Decommissioning ;
   owl:annotatedProperty <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> ;
   owl:annotatedTarget """the set of administrative and technical actions taken to allow the
removal of some or all of the regulatory controls from a facility. This does not apply for that part of a disposal facility in which radioactive waste is emplaced.""" ;
   rdfs:isDefinedBy """IAEA-TECDOC-2029,Taxonomyfordecommissiong
2.2.1.Decommissioning"""
 ] .


###  https://w3id.org/emmo/domain/decommissioning#DecommissioningPlanning
:DecommissioningPlanning rdf:type owl:Class ;
                         rdfs:subClassOf elite:Process ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty elite:isSubProcessOf ;
                                           owl:someValuesFrom :PreparationForDecommissioning
                                         ] ;
                         <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> """the preparation and maintenance (throughout the facility
lifetime) of a plan and supporting documents –- to show how decommissioning can safely achieve
the defined end state, in accordance with regulatory requirements.""" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :DecommissioningPlanning ;
   owl:annotatedProperty <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> ;
   owl:annotatedTarget """the preparation and maintenance (throughout the facility
lifetime) of a plan and supporting documents –- to show how decommissioning can safely achieve
the defined end state, in accordance with regulatory requirements.""" ;
   rdfs:isDefinedBy "https://www.iaea.org/publications/15456/a-taxonomy-for-the-decommissioning-of-nuclear-facilities"
 ] .


###  https://w3id.org/emmo/domain/decommissioning#Decontamination
:Decontamination rdf:type owl:Class ;
                 rdfs:subClassOf elite:Process ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty elite:isBefore ;
                                   owl:someValuesFrom :Dismantling
                                 ] ;
                 <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> """the complete or partial removal of contamination by a deliberate
physical, chemical or biological process.""" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :Decontamination ;
   owl:annotatedProperty <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> ;
   owl:annotatedTarget """the complete or partial removal of contamination by a deliberate
physical, chemical or biological process.""" ;
   rdfs:isDefinedBy "https://www.iaea.org/publications/15456/a-taxonomy-for-the-decommissioning-of-nuclear-facilities"
 ] .


###  https://w3id.org/emmo/domain/decommissioning#DeferredDismantling
:DeferredDismantling rdf:type owl:Class ;
                     rdfs:subClassOf :Dismantling ;
                     <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> """Deferred dismantling is deferred after permanent shutdown. For
a nuclear installation, the nuclear fuel is first removed. Part or all
of a facility containing radioactive material is either processed or
put in such a condition that it can be put into storage. The facility
is maintained until it can subsequently be decontaminated and/or
dismantled""" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :DeferredDismantling ;
   owl:annotatedProperty <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> ;
   owl:annotatedTarget """Deferred dismantling is deferred after permanent shutdown. For
a nuclear installation, the nuclear fuel is first removed. Part or all
of a facility containing radioactive material is either processed or
put in such a condition that it can be put into storage. The facility
is maintained until it can subsequently be decontaminated and/or
dismantled""" ;
   rdfs:seeAlso "https://www-pub.iaea.org/MTCD/Publications/PDF/PUB1830_web.pdf"
 ] .


###  https://w3id.org/emmo/domain/decommissioning#Demolition
:Demolition rdf:type owl:Class ;
            rdfs:subClassOf elite:Process ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty elite:isSubProcessOf ;
                              owl:someValuesFrom :Dismantling
                            ] ;
            <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> """the taking apart, disassembling and tearing down of the structures, systems
and components of a facility (outside of a radiologically controlled area) for the purposes of
decommissioning""" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :Demolition ;
   owl:annotatedProperty <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> ;
   owl:annotatedTarget """the taking apart, disassembling and tearing down of the structures, systems
and components of a facility (outside of a radiologically controlled area) for the purposes of
decommissioning""" ;
   rdfs:comment "https://www.iaea.org/publications/15456/a-taxonomy-for-the-decommissioning-of-nuclear-facilities 2.2.5."
 ] .


###  https://w3id.org/emmo/domain/decommissioning#Dismantling
:Dismantling rdf:type owl:Class ;
             rdfs:subClassOf elite:Process ;
             <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> """the taking apart, disassembling and tearing down of the structures, systems
and components of a facility (within a radiologically controlled area) for the purposes of
decommissioning.""" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :Dismantling ;
   owl:annotatedProperty <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> ;
   owl:annotatedTarget """the taking apart, disassembling and tearing down of the structures, systems
and components of a facility (within a radiologically controlled area) for the purposes of
decommissioning.""" ;
   rdfs:isDefinedBy "https://www.iaea.org/publications/15456/a-taxonomy-for-the-decommissioning-of-nuclear-facilities 2.2.4."
 ] .


###  https://w3id.org/emmo/domain/decommissioning#FacilityCharacterization
:FacilityCharacterization rdf:type owl:Class ;
                          rdfs:subClassOf :Characterization ;
                          <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> """the determination of the physical, chemical and radiological
nature of the structures, systems and components for the purpose of informing activities and
decisions.""" .


###  https://w3id.org/emmo/domain/decommissioning#FacilityManagement
:FacilityManagement rdf:type owl:Class ;
                    rdfs:subClassOf elite:Process ;
                    <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> """all activities to verify and assure the performance of facility
structures, systems and components of a nuclear facility, to assure the safety and security of the
facility and to coordinate decommissioning activities across a facility.""" .


###  https://w3id.org/emmo/domain/decommissioning#FacilityRadiationSurvey
:FacilityRadiationSurvey rdf:type owl:Class ;
                         rdfs:subClassOf elite:Process ;
                         <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> """the final radiological characterization survey of the facility and
site following the completion of decommissioning to assure the end state for the facility has been
achieved.""" .


###  https://w3id.org/emmo/domain/decommissioning#FacilityReconfiguration
:FacilityReconfiguration rdf:type owl:Class ;
                         rdfs:subClassOf elite:Process ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty elite:isBefore ;
                                           owl:someValuesFrom :Cutting
                                         ] ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty elite:isBefore ;
                                           owl:someValuesFrom :ResidualVolumeReduction
                                         ] ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty elite:isSubProcessOf ;
                                           owl:someValuesFrom :Dismantling
                                         ] ;
                         <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> """the modification of structures, systems, components and access
routes within the facility to support decommissioning activities, including where necessary the
provision of safe enclosure(s).""" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :FacilityReconfiguration ;
   owl:annotatedProperty <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> ;
   owl:annotatedTarget """the modification of structures, systems, components and access
routes within the facility to support decommissioning activities, including where necessary the
provision of safe enclosure(s).""" ;
   rdfs:isDefinedBy "https://www.iaea.org/publications/15456/a-taxonomy-for-the-decommissioning-of-nuclear-facilities"
 ] .


###  https://w3id.org/emmo/domain/decommissioning#FinancingDecommissioning
:FinancingDecommissioning rdf:type owl:Class ;
                          rdfs:subClassOf elite:Process ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty elite:isSubProcessOf ;
                                            owl:someValuesFrom :PreparationForDecommissioning
                                          ] ;
                          rdfs:comment "is part of preparationoofdecommissioning" ;
                          <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> """all activities required to ensure adequate financial resources are available
when necessary for safe decommissioning.""" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :FinancingDecommissioning ;
   owl:annotatedProperty <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> ;
   owl:annotatedTarget """all activities required to ensure adequate financial resources are available
when necessary for safe decommissioning.""" ;
   rdfs:isDefinedBy "https://www.iaea.org/publications/15456/a-taxonomy-for-the-decommissioning-of-nuclear-facilities"
 ] .


###  https://w3id.org/emmo/domain/decommissioning#FuelRemoval
:FuelRemoval rdf:type owl:Class ;
             rdfs:subClassOf :PostOperation .


###  https://w3id.org/emmo/domain/decommissioning#ImmediateDismantling
:ImmediateDismantling rdf:type owl:Class ;
                      rdfs:subClassOf :Dismantling ;
                      <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> """Immediate dismantling begins shortly after permanent shutdown.
Equipment and the structures, systems and components of a
facility containing radioactive material are removed and/or are
decontaminated to a level that permits the removal of regulatory
control from the facility and its release, either for unrestricted use or
with restrictions on its future use.""" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :ImmediateDismantling ;
   owl:annotatedProperty <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> ;
   owl:annotatedTarget """Immediate dismantling begins shortly after permanent shutdown.
Equipment and the structures, systems and components of a
facility containing radioactive material are removed and/or are
decontaminated to a level that permits the removal of regulatory
control from the facility and its release, either for unrestricted use or
with restrictions on its future use.""" ;
   rdfs:isDefinedBy "https://www-pub.iaea.org/MTCD/Publications/PDF/PUB1830_web.pdf"
 ] .


###  https://w3id.org/emmo/domain/decommissioning#Inspection
:Inspection rdf:type owl:Class ;
            rdfs:subClassOf elite:Process ;
            <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> """the examination, observation, surveillance, measurement or tests undertaken
to assess structures, systems and components and materials, as well as operational activities,
technical processes, organizational processes, procedures and personnel competence.""" .


###  https://w3id.org/emmo/domain/decommissioning#LogisticReconfiguration
:LogisticReconfiguration rdf:type owl:Class ;
                         rdfs:subClassOf elite:Process ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty elite:isSubProcessOf ;
                                           owl:someValuesFrom :PreparationForDecommissioning
                                         ] ;
                         <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> """the modification of logistics facilities and services to enable
decommissioning activities.""" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :LogisticReconfiguration ;
   owl:annotatedProperty <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> ;
   owl:annotatedTarget """the modification of logistics facilities and services to enable
decommissioning activities.""" ;
   rdfs:isDefinedBy "https://www.iaea.org/publications/15456/a-taxonomy-for-the-decommissioning-of-nuclear-facilities"
 ] .


###  https://w3id.org/emmo/domain/decommissioning#Maintanance
:Maintanance rdf:type owl:Class ;
             rdfs:subClassOf elite:Process ;
             <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> """the organized activity, both administrative and technical, of keeping
structures, systems and components in good operating condition, including both preventive and
corrective (or repair) aspects.""" .


###  https://w3id.org/emmo/domain/decommissioning#ManagementSystem
:ManagementSystem rdf:type owl:Class ;
                  rdfs:subClassOf elite:Process ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty elite:isSubProcessOf ;
                                    owl:someValuesFrom :PreparationForDecommissioning
                                  ] ;
                  <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> """a set of interrelated or interacting elements (system) for
establishing policies and objectives and enabling the objectives to be achieved in an efficient and
effective manner.""" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :ManagementSystem ;
   owl:annotatedProperty <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> ;
   owl:annotatedTarget """a set of interrelated or interacting elements (system) for
establishing policies and objectives and enabling the objectives to be achieved in an efficient and
effective manner.""" ;
   rdfs:isDefinedBy "https://www.iaea.org/publications/15456/a-taxonomy-for-the-decommissioning-of-nuclear-facilities"
 ] .


###  https://w3id.org/emmo/domain/decommissioning#MaterialManagement
:MaterialManagement rdf:type owl:Class ;
                    rdfs:subClassOf elite:Process ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty elite:isSubProcessOf ;
                                      owl:someValuesFrom :Dismantling
                                    ] ;
                    <http://www.w3.org/2004/02/skos/core#definition> "sepration of different materials" .


###  https://w3id.org/emmo/domain/decommissioning#PermanentDisposal
:PermanentDisposal rdf:type owl:Class ;
                   rdfs:subClassOf elite:Object .


###  https://w3id.org/emmo/domain/decommissioning#PostDecommissioningArrangements
:PostDecommissioningArrangements rdf:type owl:Class ;
                                 rdfs:subClassOf elite:Process ;
                                 <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> """establishing arrangements to assure that any
remaining authorized responsibilities are adequately discharged.""" .


###  https://w3id.org/emmo/domain/decommissioning#PostOperation
:PostOperation rdf:type owl:Class ;
               rdfs:subClassOf elite:Process ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty elite:isBefore ;
                                 owl:someValuesFrom :Decommissioning
                               ] ;
               <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> """all activities relating to the permanent cessation of operation of a nuclear
facility.""" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :PostOperation ;
   owl:annotatedProperty <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> ;
   owl:annotatedTarget """all activities relating to the permanent cessation of operation of a nuclear
facility.""" ;
   rdfs:isDefinedBy "https://www.iaea.org/publications/15456/a-taxonomy-for-the-decommissioning-of-nuclear-facilities 2.2.3."
 ] .


###  https://w3id.org/emmo/domain/decommissioning#PostShutDownActivities
:PostShutDownActivities rdf:type owl:Class ;
                        rdfs:subClassOf :PostOperation ;
                        <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> """activities undertaken following permanent shutdown of a
nuclear facility to reduce hazards and prepare the facility for immediate or deferred dismantling.""" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :PostShutDownActivities ;
   owl:annotatedProperty <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> ;
   owl:annotatedTarget """activities undertaken following permanent shutdown of a
nuclear facility to reduce hazards and prepare the facility for immediate or deferred dismantling.""" ;
   rdfs:isDefinedBy "https://www.iaea.org/publications/15456/a-taxonomy-for-the-decommissioning-of-nuclear-facilities"
 ] .


###  https://w3id.org/emmo/domain/decommissioning#PreparationForDecommissioning
:PreparationForDecommissioning rdf:type owl:Class ;
                               rdfs:subClassOf elite:Process ,
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty elite:isSubProcessOf ;
                                                 owl:someValuesFrom :Decommissioning
                                               ] ;
                               <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> """all activities required for authorization of
decommissioning.""" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :PreparationForDecommissioning ;
   owl:annotatedProperty <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> ;
   owl:annotatedTarget """all activities required for authorization of
decommissioning.""" ;
   rdfs:isDefinedBy "IAEA-TECDOC-2029,Taxonomyfordecommissiong 2.2.2."
 ] .


###  https://w3id.org/emmo/domain/decommissioning#PrimaryResidue
:PrimaryResidue rdf:type owl:Class ;
                rdfs:subClassOf :Residue .


###  https://w3id.org/emmo/domain/decommissioning#RadioactiveWaste
:RadioactiveWaste rdf:type owl:Class ;
                  rdfs:subClassOf elite:Object .


###  https://w3id.org/emmo/domain/decommissioning#RemoteOperation
:RemoteOperation rdf:type owl:Class ;
                 rdfs:subClassOf <https://w3id.org/emmo/domain/neo#RlYMwSSvmqekLRLzmf5IzV> ;
                 <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> """the ability to perform activities that are physically distant from an
operator""" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :RemoteOperation ;
   owl:annotatedProperty <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> ;
   owl:annotatedTarget """the ability to perform activities that are physically distant from an
operator""" ;
   rdfs:isDefinedBy "https://www.iaea.org/publications/15456/a-taxonomy-for-the-decommissioning-of-nuclear-facilities"
 ] .


###  https://w3id.org/emmo/domain/decommissioning#ResidualClassification
:ResidualClassification rdf:type owl:Class ;
                        rdfs:subClassOf elite:Process .


###  https://w3id.org/emmo/domain/decommissioning#ResidualVolumeReduction
:ResidualVolumeReduction rdf:type owl:Class ;
                         rdfs:subClassOf elite:Process ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty elite:isBefore ;
                                           owl:someValuesFrom :ContainerForTransportation
                                         ] ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty elite:isSubProcessOf ;
                                           owl:someValuesFrom :Dismantling
                                         ] ;
                         <http://www.w3.org/2004/02/skos/core#definition> "step or steps taken to reduce (3.2.6) the volume of radioactive waste (3.2.1)" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :ResidualVolumeReduction ;
   owl:annotatedProperty <http://www.w3.org/2004/02/skos/core#definition> ;
   owl:annotatedTarget "step or steps taken to reduce (3.2.6) the volume of radioactive waste (3.2.1)" ;
   rdfs:isDefinedBy "https://www.iso.org/obp/ui/en/#iso:std:iso:24389:-1:ed-1:v1:en:term:3.2.1"
 ] .


###  https://w3id.org/emmo/domain/decommissioning#Residue
:Residue rdf:type owl:Class ;
         rdfs:subClassOf elite:Object .


###  https://w3id.org/emmo/domain/decommissioning#SecondaryResidue
:SecondaryResidue rdf:type owl:Class ;
                  rdfs:subClassOf :Residue ;
                  <http://www.w3.org/2004/02/skos/core#comment> "help Susanne" .


###  https://w3id.org/emmo/domain/decommissioning#SiteCharacterization
:SiteCharacterization rdf:type owl:Class ;
                      rdfs:subClassOf :Characterization ;
                      <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> """the determination of the physical nature of a site, and of any
potential chemical and radiological contamination for the purpose of informing activities and
decisions.""" .


###  https://w3id.org/emmo/domain/decommissioning#SiteSecurity
:SiteSecurity rdf:type owl:Class ;
              rdfs:subClassOf elite:Process ;
              <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> """the prevention and detection of, and response to, criminal or intentional
unauthorized acts involving nuclear material, other radioactive material, associated facilities or
associated activities.""" .


###  https://w3id.org/emmo/domain/decommissioning#SpentFuelRemoval
:SpentFuelRemoval rdf:type owl:Class ;
                  rdfs:subClassOf :PostOperation ;
                  <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> """the removal of spent fuel from a reactor core and transfer of fuel to
spent fuel storage.""" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :SpentFuelRemoval ;
   owl:annotatedProperty <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> ;
   owl:annotatedTarget """the removal of spent fuel from a reactor core and transfer of fuel to
spent fuel storage.""" ;
   rdfs:isDefinedBy "https://www.iaea.org/publications/15456/a-taxonomy-for-the-decommissioning-of-nuclear-facilities"
 ] .


###  https://w3id.org/emmo/domain/decommissioning#SupervisedArea
:SupervisedArea rdf:type owl:Class ;
                rdfs:subClassOf elite:Object ;
                <http://www.w3.org/2004/02/skos/core#altLabel> "MonitoredArea" ;
                <http://www.w3.org/2004/02/skos/core#definition> "defined area not designated as a controlled area (3.6.5) but for which occupational exposure (3.3.31) conditions are kept under review, even though specific protection measures or safety provisions are not normally needed" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :SupervisedArea ;
   owl:annotatedProperty <http://www.w3.org/2004/02/skos/core#definition> ;
   owl:annotatedTarget "defined area not designated as a controlled area (3.6.5) but for which occupational exposure (3.3.31) conditions are kept under review, even though specific protection measures or safety provisions are not normally needed" ;
   rdfs:isDefinedBy "[SOURCE:IAEA. IAEA safety glossary: 2018 edition. Vienna: IAEA, 2019. p. 278]"
 ] .


###  https://w3id.org/emmo/domain/decommissioning#TemporaryDisposal
:TemporaryDisposal rdf:type owl:Class ;
                   rdfs:subClassOf elite:Object .


###  https://w3id.org/emmo/domain/decommissioning#TerminationOfAuthorization
:TerminationOfAuthorization rdf:type owl:Class ;
                            rdfs:subClassOf elite:Process ;
                            <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> """the termination of the nuclear decommissioning
authorization or license for the facility, either unconditionally or with stipulated conditions on the
future use of the facility site.""" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :TerminationOfAuthorization ;
   owl:annotatedProperty <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> ;
   owl:annotatedTarget """the termination of the nuclear decommissioning
authorization or license for the facility, either unconditionally or with stipulated conditions on the
future use of the facility site.""" ;
   rdfs:isDefinedBy "IAEA-TECDOC-2029,Taxonomyfordecommissiong 2.2.7."
 ] .


###  https://w3id.org/emmo/domain/decommissioning#UncontrolledArea
:UncontrolledArea rdf:type owl:Class ;
                  rdfs:subClassOf elite:Object ;
                  <http://www.w3.org/2004/02/skos/core#altLabel> "OffsiteArea" .


###  https://w3id.org/emmo/domain/decommissioning#Waste
:Waste rdf:type owl:Class ;
       rdfs:subClassOf elite:Object ;
       <http://www.w3.org/2004/02/skos/core#definition> "any residue of a production operation, transformation or use, any substance, material, product that its holder intends for disposal" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource :Waste ;
   owl:annotatedProperty <http://www.w3.org/2004/02/skos/core#definition> ;
   owl:annotatedTarget "any residue of a production operation, transformation or use, any substance, material, product that its holder intends for disposal" ;
   rdfs:isDefinedBy "ISO 22716:2007(en), 2.36"
 ] .


###  https://w3id.org/emmo/domain/decommissioning#WasteCharacterization
:WasteCharacterization rdf:type owl:Class ;
                       rdfs:subClassOf :Characterization ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty elite:isBefore ;
                                         owl:someValuesFrom :ClearanceVerification
                                       ] ;
                       <https://w3id.org/emmo/domain/neo#R8xx0dhbEh1tjGMDwNZfckV> """the determination of the physical, mechanical, chemical,
radiological and biological properties of radioactive waste to establish the need for further
adjustment, treatment or conditioning, or its suitability for further handling, processing, storage
or disposal.""" .


###  https://w3id.org/emmo/domain/neo#RCNShAJHX3mIvlEif02qYJZ
<https://w3id.org/emmo/domain/neo#RCNShAJHX3mIvlEif02qYJZ> rdfs:subClassOf :Decommissioning .


